'use client';

import { useState, useEffect, useCallback } from 'react';
import { useRouter } from 'next/navigation';
import { motion, AnimatePresence } from 'framer-motion';
import { Card, CardContent, CardDescription, CardHeader, CardTitle } from '@/components/ui/card';
import { Button } from '@/components/ui/button';
import { Input } from '@/components/ui/input';
import { Label } from '@/components/ui/label';
import { Textarea } from '@/components/ui/textarea';
import { Select, SelectContent, SelectItem, SelectTrigger, SelectValue } from '@/components/ui/select';
import { Checkbox } from '@/components/ui/checkbox';
import { RadioGroup, RadioGroupItem } from '@/components/ui/radio-group';
import { Badge } from '@/components/ui/badge';
import { Alert, AlertDescription } from '@/components/ui/alert';
import { useToast } from '@/hooks/use-toast';
import { 
  UserPlus, 
  Phone, 
  MapPin, 
  Users, 
  Briefcase, 
  TrendingUp, 
  Banknote, 
  Building2, 
  Eye, 
  FileText,
  Save,
  ArrowLeft,
  ArrowRight,
  ChevronLeft,
  ChevronRight,
  Clock,
  CheckCircle2,
  AlertCircle,
  RotateCcw,
  Sparkles
} from 'lucide-react';

// 새로 만든 컴포넌트들 import
import StepIndicator, { Step } from '@/components/forms/StepIndicator';
import SmartPhoneInput from '@/components/forms/SmartPhoneInput';
import AutoCompleteInput, { AREA_OPTIONS, OCCUPATION_OPTIONS } from '@/components/forms/AutoCompleteInput';
import useAutoSave from '@/hooks/useAutoSave';
import useFormValidation, { validationSchemas } from '@/hooks/useFormValidation';
import { cn } from '@/lib/utils';

export default function NewCustomerPage() {
  const router = useRouter();
  const { toast } = useToast();
  const [isSubmitting, setIsSubmitting] = useState(false);
  const [currentStep, setCurrentStep] = useState(1);
  const [showRestorePrompt, setShowRestorePrompt] = useState(false);

  // 폼 상태 관리
  const [formData, setFormData] = useState({
    // 기본 정보 (Step 1)
    name: '',
    phone: '',
    
    // 개인 정보 (Step 2)
    gender: '',
    ageRange: '',
    residenceArea: '',
    familyRelation: '',
    
    // 투자 정보 (Step 3)
    occupation: '',
    investHabit: '',
    expectedBudget: '',
    ownAssets: [] as string[],
    
    // 부가 정보 (Step 4)
    lastVisitMH: '',
    source: '',
    notes: ''
  });

  // 스텝 정의
  const steps: Step[] = [
    {
      id: 1,
      title: '기본 정보',
      description: '이름과 연락처 등 필수 정보',
      isCompleted: false,
      isActive: currentStep === 1
    },
    {
      id: 2,
      title: '개인 정보',
      description: '성별, 나이, 거주지, 가족관계',
      isCompleted: false,
      isActive: currentStep === 2
    },
    {
      id: 3,
      title: '투자 정보',
      description: '직업, 투자성향, 예상금액, 보유자산',
      isCompleted: false,
      isActive: currentStep === 3
    },
    {
      id: 4,
      title: '부가 정보',
      description: '방문이력, 유입경로, 특이사항',
      isCompleted: false,
      isActive: currentStep === 4
    }
  ];

  // 각 스텝의 필드 정의
  const stepFields = {
    1: ['name', 'phone'],
    2: ['gender', 'ageRange', 'residenceArea', 'familyRelation'],
    3: ['occupation', 'investHabit', 'expectedBudget', 'ownAssets'],
    4: ['lastVisitMH', 'source', 'notes']
  };

  const requiredFields = ['name', 'phone'];

  // 유효성 검사 규칙
  const validationRules = [
    { field: 'name', schema: validationSchemas.name },
    { field: 'phone', schema: validationSchemas.phone },
    // 선택적 필드들은 빈 값이어도 유효
    { field: 'gender', schema: validationSchemas.gender.optional() },
    { field: 'ageRange', schema: validationSchemas.ageRange.optional() },
  ];

  // 폼 유효성 검사
  const validation = useFormValidation({
    rules: validationRules,
    data: formData,
    requiredFields,
    mode: 'onChange'
  });

  // 자동저장 기능
  const autoSave = useAutoSave({
    key: 'customer_form',
    data: formData,
    delay: 2000,
    enabled: true,
    showToast: false,
    onRestore: (restoredData) => {
      setFormData(restoredData);
      setShowRestorePrompt(false);
    }
  });

  // 컴포넌트 마운트 시 저장된 데이터 확인
  useEffect(() => {
    if (autoSave.hasSavedData()) {
      setShowRestorePrompt(true);
    }
  }, []);

  // 스텝 완료 상태 업데이트
  useEffect(() => {
    steps.forEach((step, index) => {
      const fields = stepFields[step.id as keyof typeof stepFields];
      step.isCompleted = validation.isStepComplete(fields);
      step.isActive = currentStep === step.id;
    });
  }, [currentStep, validation, formData]);

  const handleInputChange = (field: string, value: string | number) => {
    setFormData(prev => ({ ...prev, [field]: value }));
  };

  const handleCheckboxChange = (field: string, value: string, checked: boolean) => {
    setFormData(prev => ({
      ...prev,
      [field]: checked 
        ? [...(prev[field as keyof typeof prev] as string[]), value]
        : (prev[field as keyof typeof prev] as string[]).filter(item => item !== value)
    }));
  };

  const handleStepClick = (stepId: number) => {
    // 이전 스텝들이 완료된 경우에만 이동 허용
    const canNavigate = steps
      .slice(0, stepId - 1)
      .every(step => step.isCompleted);
    
    if (canNavigate) {
      setCurrentStep(stepId);
    }
  };

  const handleNext = () => {
    const currentFields = stepFields[currentStep as keyof typeof stepFields];
    const isStepValid = validation.isStepComplete(currentFields);
    
    if (currentStep === 1 && !isStepValid) {
      toast({
        title: '필수 정보 입력',
        description: '이름과 연락처는 필수 입력 항목입니다.',
        variant: 'destructive'
      });
      return;
    }
    
    if (currentStep < steps.length) {
      setCurrentStep(prev => prev + 1);
    }
  };

  const handlePrev = () => {
    if (currentStep > 1) {
      setCurrentStep(prev => prev - 1);
    }
  };

  const handleRestoreData = () => {
    autoSave.restore();
    setShowRestorePrompt(false);
  };

  const handleDiscardSaved = () => {
    autoSave.clearStorage();
    setShowRestorePrompt(false);
  };

  const handleSubmit = async (e: React.FormEvent) => {
    e.preventDefault();
    
    // 최종 유효성 검사
    const allErrors = await validation.validateAllFields();
    if (Object.keys(allErrors).length > 0) {
      toast({
        title: '입력 오류',
        description: '모든 필수 항목을 올바르게 입력해주세요.',
        variant: 'destructive'
      });
      return;
    }
    
    setIsSubmitting(true);

    try {
      const response = await fetch('/api/customers', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify({
          ...formData,
          expectedBudget: formData.expectedBudget ? parseInt(formData.expectedBudget) : null,
          ownAssets: formData.ownAssets.join(', ')
        }),
      });

      if (response.ok) {
        // 성공 시 저장된 임시 데이터 삭제
        autoSave.clearStorage();
        
        toast({
          title: '고객 등록 성공',
          description: '새로운 고객이 성공적으로 등록되었습니다.',
        });
        router.push('/dashboard/customers');
      } else {
        const error = await response.json();
        throw new Error(error.message || '고객 등록에 실패했습니다.');
      }
    } catch (error) {
      toast({
        title: '등록 실패',
        description: error instanceof Error ? error.message : '알 수 없는 오류가 발생했습니다.',
        variant: 'destructive',
      });
    } finally {
      setIsSubmitting(false);
    }
  };

  // 스텝별 컨텐츠 렌더링
  const renderStepContent = () => {
    switch (currentStep) {
      case 1:
        return (
          <motion.div
            key="step1"
            initial={{ opacity: 0, x: 20 }}
            animate={{ opacity: 1, x: 0 }}
            exit={{ opacity: 0, x: -20 }}
            transition={{ duration: 0.3 }}
            className="space-y-6"
          >
            <div className="text-center mb-8">
              <Sparkles className="h-12 w-12 text-blue-500 mx-auto mb-4" />
              <h2 className="text-2xl font-bold text-gray-900 mb-2">기본 정보</h2>
              <p className="text-gray-600">고객의 기본적인 식별 정보를 입력해주세요</p>
            </div>

            <div className="space-y-6">
              <div>
                <Label htmlFor="name" className="flex items-center gap-2 font-medium">
                  <Users className="h-4 w-4" />
                  성명 *
                </Label>
                <Input
                  id="name"
                  value={formData.name}
                  onChange={(e) => handleInputChange('name', e.target.value)}
                  placeholder="고객명을 입력하세요"
                  className={cn(
                    "mt-2 transition-all duration-300",
                    validation.getFieldStatus('name').hasError && "border-red-500 ring-red-500/20 ring-2",
                    validation.getFieldStatus('name').isValid && "border-green-500 ring-green-500/20 ring-2"
                  )}
                  autoComplete="name"
                  autoFocus
                />
                {validation.getFieldStatus('name').error && (
                  <p className="text-sm text-red-600 mt-1 flex items-center gap-1">
                    <AlertCircle className="h-3 w-3" />
                    {validation.getFieldStatus('name').error.message}
                  </p>
                )}
              </div>

              <SmartPhoneInput
                value={formData.phone}
                onChange={(value) => handleInputChange('phone', value)}
                onValidation={(isValid) => {}}
                label="연락처"
                placeholder="010-1234-5678"
                required
              />
            </div>
          </motion.div>
        );

      case 2:
        return (
          <motion.div
            key="step2"
            initial={{ opacity: 0, x: 20 }}
            animate={{ opacity: 1, x: 0 }}
            exit={{ opacity: 0, x: -20 }}
            transition={{ duration: 0.3 }}
            className="space-y-6"
          >
            <div className="text-center mb-8">
              <Users className="h-12 w-12 text-green-500 mx-auto mb-4" />
              <h2 className="text-2xl font-bold text-gray-900 mb-2">개인 정보</h2>
              <p className="text-gray-600">고객의 개인적인 특성을 입력해주세요</p>
            </div>

            <div className="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div className="space-y-3">
                <Label className="flex items-center gap-2 font-medium">
                  <Users className="h-4 w-4" />
                  성별
                </Label>
                <RadioGroup
                  value={formData.gender}
                  onValueChange={(value) => handleInputChange('gender', value)}
                  className="flex gap-6 mt-2"
                >
                  <div className="flex items-center space-x-2">
                    <RadioGroupItem value="남성" id="male" />
                    <Label htmlFor="male">남성</Label>
                  </div>
                  <div className="flex items-center space-x-2">
                    <RadioGroupItem value="여성" id="female" />
                    <Label htmlFor="female">여성</Label>
                  </div>
                </RadioGroup>
              </div>

              <div className="space-y-2">
                <Label className="flex items-center gap-2 font-medium">
                  <Users className="h-4 w-4" />
                  나이대
                </Label>
                <Select value={formData.ageRange} onValueChange={(value) => handleInputChange('ageRange', value)}>
                  <SelectTrigger className="mt-2">
                    <SelectValue placeholder="나이대를 선택하세요" />
                  </SelectTrigger>
                  <SelectContent>
                    <SelectItem value="20대">20대</SelectItem>
                    <SelectItem value="30대">30대</SelectItem>
                    <SelectItem value="40대">40대</SelectItem>
                    <SelectItem value="50대">50대</SelectItem>
                    <SelectItem value="60대 이상">60대 이상</SelectItem>
                  </SelectContent>
                </Select>
              </div>

              <AutoCompleteInput
                value={formData.residenceArea}
                onChange={(value) => handleInputChange('residenceArea', value)}
                options={AREA_OPTIONS}
                label="거주지역"
                placeholder="거주 지역을 입력하세요"
                icon={<MapPin className="h-4 w-4" />}
                showRecentSuggestions
              />

              <div className="space-y-2">
                <Label className="flex items-center gap-2 font-medium">
                  <Users className="h-4 w-4" />
                  가족관계
                </Label>
                <Select value={formData.familyRelation} onValueChange={(value) => handleInputChange('familyRelation', value)}>
                  <SelectTrigger className="mt-2">
                    <SelectValue placeholder="가족 구성을 선택하세요" />
                  </SelectTrigger>
                  <SelectContent>
                    <SelectItem value="미혼">미혼</SelectItem>
                    <SelectItem value="기혼(무자녀)">기혼(무자녀)</SelectItem>
                    <SelectItem value="기혼(자녀1명)">기혼(자녀1명)</SelectItem>
                    <SelectItem value="기혼(자녀2명)">기혼(자녀2명)</SelectItem>
                    <SelectItem value="기혼(자녀3명 이상)">기혼(자녀3명 이상)</SelectItem>
                  </SelectContent>
                </Select>
              </div>
            </div>
          </motion.div>
        );

      case 3:
        return (
          <motion.div
            key="step3"
            initial={{ opacity: 0, x: 20 }}
            animate={{ opacity: 1, x: 0 }}
            exit={{ opacity: 0, x: -20 }}
            transition={{ duration: 0.3 }}
            className="space-y-6"
          >
            <div className="text-center mb-8">
              <TrendingUp className="h-12 w-12 text-purple-500 mx-auto mb-4" />
              <h2 className="text-2xl font-bold text-gray-900 mb-2">투자 정보</h2>
              <p className="text-gray-600">고객의 투자 성향과 관련 정보를 입력해주세요</p>
            </div>

            <div className="space-y-6">
              <div className="grid grid-cols-1 md:grid-cols-2 gap-6">
                <AutoCompleteInput
                  value={formData.occupation}
                  onChange={(value) => handleInputChange('occupation', value)}
                  options={OCCUPATION_OPTIONS}
                  label="직업"
                  placeholder="직업을 입력하세요"
                  icon={<Briefcase className="h-4 w-4" />}
                  showRecentSuggestions
                />

                <div className="space-y-2">
                  <Label className="flex items-center gap-2 font-medium">
                    <TrendingUp className="h-4 w-4" />
                    투자성향
                  </Label>
                  <Select value={formData.investHabit} onValueChange={(value) => handleInputChange('investHabit', value)}>
                    <SelectTrigger className="mt-2">
                      <SelectValue placeholder="투자 목적을 선택하세요" />
                    </SelectTrigger>
                    <SelectContent>
                      <SelectItem value="시세차익">시세차익</SelectItem>
                      <SelectItem value="월수익">월수익(임대)</SelectItem>
                      <SelectItem value="실거주">실거주</SelectItem>
                      <SelectItem value="복합">복합</SelectItem>
                    </SelectContent>
                  </Select>
                </div>
              </div>

              <div className="space-y-2">
                <Label htmlFor="expectedBudget" className="flex items-center gap-2 font-medium">
                  <Banknote className="h-4 w-4" />
                  예상투자 가능금액 (계약금 기준)
                </Label>
                <Input
                  id="expectedBudget"
                  type="number"
                  value={formData.expectedBudget}
                  onChange={(e) => handleInputChange('expectedBudget', e.target.value)}
                  placeholder="예) 50000000 (5천만원)"
                  className="mt-2"
                />
              </div>

              <div className="space-y-4">
                <Label className="flex items-center gap-2 font-medium">
                  <Building2 className="h-4 w-4" />
                  보유한 부동산 (복수 선택 가능)
                </Label>
                <div className="grid grid-cols-2 md:grid-cols-4 gap-3 mt-2">
                  {[
                    '아파트', '빌라', '오피스텔', '상가',
                    '토지', '주택', '펜션', '기타'
                  ].map((asset) => (
                    <div key={asset} className="flex items-center space-x-2 p-2 border rounded-lg hover:bg-gray-50">
                      <Checkbox
                        id={asset}
                        checked={formData.ownAssets.includes(asset)}
                        onCheckedChange={(checked) => handleCheckboxChange('ownAssets', asset, checked as boolean)}
                      />
                      <Label htmlFor={asset} className="text-sm">{asset}</Label>
                    </div>
                  ))}
                </div>
              </div>
            </div>
          </motion.div>
        );

      case 4:
        return (
          <motion.div
            key="step4"
            initial={{ opacity: 0, x: 20 }}
            animate={{ opacity: 1, x: 0 }}
            exit={{ opacity: 0, x: -20 }}
            transition={{ duration: 0.3 }}
            className="space-y-6"
          >
            <div className="text-center mb-8">
              <FileText className="h-12 w-12 text-orange-500 mx-auto mb-4" />
              <h2 className="text-2xl font-bold text-gray-900 mb-2">부가 정보</h2>
              <p className="text-gray-600">마케팅 및 영업 관련 추가 정보를 입력해주세요</p>
            </div>

            <div className="space-y-6">
              <div className="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div className="space-y-2">
                  <Label htmlFor="lastVisitMH" className="flex items-center gap-2 font-medium">
                    <Eye className="h-4 w-4" />
                    최근 방문 모델하우스
                  </Label>
                  <Input
                    id="lastVisitMH"
                    value={formData.lastVisitMH}
                    onChange={(e) => handleInputChange('lastVisitMH', e.target.value)}
                    placeholder="예) 강남 래미안, 서초 자이"
                    className="mt-2"
                  />
                </div>

                <div className="space-y-2">
                  <Label className="flex items-center gap-2 font-medium">
                    <Users className="h-4 w-4" />
                    유입경로
                  </Label>
                  <Select value={formData.source} onValueChange={(value) => handleInputChange('source', value)}>
                    <SelectTrigger className="mt-2">
                      <SelectValue placeholder="고객 유입 경로를 선택하세요" />
                    </SelectTrigger>
                    <SelectContent>
                      <SelectItem value="광고">광고</SelectItem>
                      <SelectItem value="TM">TM</SelectItem>
                      <SelectItem value="필드">필드</SelectItem>
                      <SelectItem value="소개">소개</SelectItem>
                      <SelectItem value="기타">기타</SelectItem>
                    </SelectContent>
                  </Select>
                </div>
              </div>

              <div className="space-y-2">
                <Label htmlFor="notes" className="flex items-center gap-2 font-medium">
                  <FileText className="h-4 w-4" />
                  특이사항
                </Label>
                <Textarea
                  id="notes"
                  value={formData.notes}
                  onChange={(e) => handleInputChange('notes', e.target.value)}
                  placeholder="고객과 관련된 중요한 특이사항이나 메모를 입력하세요"
                  rows={4}
                  className="mt-2"
                />
              </div>
            </div>
          </motion.div>
        );

      default:
        return null;
    }
  };

  return (
    <div className="min-h-screen bg-gradient-to-br from-slate-50 via-blue-50/30 to-indigo-50/30">
      {/* 복원 프롬프트 */}
      <AnimatePresence>
        {showRestorePrompt && (
          <motion.div
            initial={{ opacity: 0, y: -50 }}
            animate={{ opacity: 1, y: 0 }}
            exit={{ opacity: 0, y: -50 }}
            className="fixed top-4 left-1/2 transform -translate-x-1/2 z-50"
          >
            <Alert className="w-96 bg-white border-blue-200 shadow-lg">
              <RotateCcw className="h-4 w-4" />
              <AlertDescription className="flex items-center justify-between">
                <span className="text-sm">저장된 작성 내용이 있습니다.</span>
                <div className="flex gap-2 ml-4">
                  <Button
                    size="sm"
                    variant="outline"
                    onClick={handleRestoreData}
                    className="h-7 text-xs"
                  >
                    복원
                  </Button>
                  <Button
                    size="sm"
                    variant="ghost"
                    onClick={handleDiscardSaved}
                    className="h-7 text-xs"
                  >
                    무시
                  </Button>
                </div>
              </AlertDescription>
            </Alert>
          </motion.div>
        )}
      </AnimatePresence>

      <div className="container mx-auto px-4 py-8">
        <div className="max-w-6xl mx-auto">
          {/* 헤더 */}
          <motion.div
            initial={{ opacity: 0, y: -20 }}
            animate={{ opacity: 1, y: 0 }}
            className="mb-8"
          >
            <div className="flex items-center gap-4 mb-6">
              <Button
                variant="outline"
                size="icon"
                onClick={() => router.back()}
                className="h-10 w-10"
              >
                <ArrowLeft className="h-4 w-4" />
              </Button>
              <div>
                <h1 className="text-3xl font-bold text-slate-900 flex items-center gap-3">
                  <UserPlus className="h-8 w-8 text-blue-600" />
                  온시아 고객관리카드
                </h1>
                <p className="text-slate-600 mt-1">새로운 고객 정보를 단계별로 등록합니다</p>
              </div>
            </div>

            {/* 자동저장 상태 */}
            <div className="flex items-center justify-between">
              <div className="flex items-center gap-4">
                <Badge variant="outline" className="flex items-center gap-1">
                  <div className={cn(
                    "w-2 h-2 rounded-full",
                    autoSave.status.status === 'saved' && "bg-green-500",
                    autoSave.status.status === 'saving' && "bg-yellow-500 animate-pulse",
                    autoSave.status.status === 'error' && "bg-red-500",
                    autoSave.status.status === 'idle' && "bg-gray-300"
                  )} />
                  {autoSave.status.status === 'saved' && '자동 저장됨'}
                  {autoSave.status.status === 'saving' && '저장 중...'}
                  {autoSave.status.status === 'error' && '저장 오류'}
                  {autoSave.status.status === 'idle' && '대기 중'}
                </Badge>
                {autoSave.status.lastSaved && (
                  <span className="text-xs text-gray-500">
                    마지막 저장: {autoSave.status.lastSaved.toLocaleTimeString()}
                  </span>
                )}
              </div>
            </div>
          </motion.div>

          <div className="grid grid-cols-1 lg:grid-cols-4 gap-8">
            {/* 왼쪽: 스텝 인디케이터 */}
            <div className="lg:col-span-1">
              <div className="sticky top-8">
                <StepIndicator
                  steps={steps}
                  currentStep={currentStep}
                  onStepClick={handleStepClick}
                />
              </div>
            </div>

            {/* 오른쪽: 폼 컨텐츠 */}
            <div className="lg:col-span-3">
              <form onSubmit={handleSubmit}>
                <Card className="border-0 shadow-lg bg-white/70 backdrop-blur-xl">
                  <CardContent className="p-8">
                    <AnimatePresence mode="wait">
                      {renderStepContent()}
                    </AnimatePresence>
                  </CardContent>
                </Card>

                {/* 네비게이션 버튼 */}
                <motion.div
                  initial={{ opacity: 0 }}
                  animate={{ opacity: 1 }}
                  transition={{ delay: 0.3 }}
                  className="flex justify-between mt-8"
                >
                  <Button
                    type="button"
                    variant="outline"
                    onClick={handlePrev}
                    disabled={currentStep === 1}
                    className="flex items-center gap-2"
                  >
                    <ChevronLeft className="h-4 w-4" />
                    이전
                  </Button>

                  <div className="flex gap-4">
                    {currentStep === steps.length ? (
                      <Button
                        type="submit"
                        disabled={isSubmitting || !validation.isValid}
                        className="min-w-32 flex items-center gap-2"
                      >
                        {isSubmitting ? (
                          <>
                            <div className="animate-spin rounded-full h-4 w-4 border-2 border-white border-t-transparent" />
                            저장 중...
                          </>
                        ) : (
                          <>
                            <Save className="h-4 w-4" />
                            저장하기
                          </>
                        )}
                      </Button>
                    ) : (
                      <Button
                        type="button"
                        onClick={handleNext}
                        className="flex items-center gap-2"
                      >
                        다음
                        <ChevronRight className="h-4 w-4" />
                      </Button>
                    )}
                  </div>
                </motion.div>
              </form>
            </div>
          </div>
        </div>
      </div>
    );
}